.container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: 140rpx;
  width: 100%;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  background-color: #007AFF;
  padding: 30rpx 20rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  width: 100%;
  box-sizing: border-box;
}

.menu-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.menu-line {
  width: 40rpx;
  height: 4rpx;
  background-color: #fff;
  margin-bottom: 8rpx;
  border-radius: 2rpx;
}

.menu-line:last-child {
  margin-bottom: 0;
}

.header-title {
  flex: 1;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 5rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.side-menu {
  position: fixed;
  top: 0;
  left: 0;
  width: 500rpx;
  height: 100vh;
  background-color: #fff;
  z-index: 101;
  display: flex;
  flex-direction: column;
}

.menu-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #007AFF;
}

.menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.menu-close {
  font-size: 48rpx;
  color: #fff;
  line-height: 1;
}

.menu-content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.year-list {
  margin-bottom: 30rpx;
}

.year-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}

.year-item.active {
  background-color: #e8f4fc;
}

.year-text {
  font-size: 28rpx;
  color: #333;
}

.year-arrow {
  font-size: 24rpx;
  color: #999;
}

.month-list {
  margin-left: 30rpx;
  margin-top: 10rpx;
}

.month-item {
  padding: 20rpx 25rpx;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid #eee;
}

.month-item.active {
  background-color: #007AFF;
  border-color: #007AFF;
}

.month-item.active .month-text {
  color: #fff;
}

.month-text {
  font-size: 28rpx;
  color: #666;
}

.clear-filter {
  padding: 25rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  color: #999;
  font-size: 28rpx;
}

.achievement-list {
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.stats-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #007AFF;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background-color: #eee;
  margin: 0 20rpx;
}

.stat-stars {
  display: flex;
  margin-bottom: 10rpx;
}

.stat-stars .star {
  font-size: 32rpx;
  color: #ffc107;
  margin-right: 4rpx;
}

.stat-stars .star:last-child {
  margin-right: 0;
}

.achievement-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.card-header {
  margin-bottom: 20rpx;
  width: 100%;
}

.star-rating {
  display: flex;
  align-items: center;
  background-color: #fff8e6;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.star {
  color: #ffc107;
  font-size: 28rpx;
  margin-right: 6rpx;
}

.star:last-child {
  margin-right: 0;
}

.card-content {
  margin-bottom: 20rpx;
  width: 100%;
}

.achievement-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  width: 100%;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.achievement-date {
  font-size: 24rpx;
  color: #999;
}

.delete-btn {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 10rpx 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
}

.empty-tip text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  color: #ccc !important;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #999;
}

.add-btn {
  position: fixed;
  bottom: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 100rpx;
  background-color: #4a90e2;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 226, 0.4);
}

.add-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: bold;
}
