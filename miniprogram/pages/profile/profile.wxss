.container {
  display: block;
  min-height: 100vh;
  background-color: #f6f6f6;
  padding: 0;
  margin: 0;
  width: 100%;
  box-sizing: border-box;
}

.user-section {
  background: linear-gradient(135deg, #007AFF 0%, #4a90e2 100%);
  padding: 60rpx 30rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin: 0;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  margin-bottom: 20rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
}

.nickname {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-btn {
  padding: 25rpx 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.login-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.stats-section {
  display: flex;
  background-color: #fff;
  margin: -40rpx 0 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.stat-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #007AFF;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background-color: #eee;
}

.menu-section {
  margin: 0;
  background-color: #fff;
  border-radius: 0;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 32rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.share-btn {
  width: 100%;
  padding: 35rpx 30rpx;
  background-color: #fff;
  border-radius: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.share-btn::after {
  border: none;
}

.share-btn .menu-text {
  font-size: 32rpx;
  color: #333;
}

.share-btn .menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.about-section {
  margin: 0;
  background-color: #fff;
  border-radius: 0;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.about-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.about-item:last-child {
  border-bottom: none;
}

.about-text {
  font-size: 32rpx;
  color: #333;
}

.about-value {
  font-size: 28rpx;
  color: #999;
}

.footer {
  text-align: center;
  padding: 60rpx 30rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #ccc;
}
