.container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding: 0;
  padding-bottom: 140rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-section {
  background-color: #fff;
  border-radius: 0;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.textarea {
  width: 100%;
  min-height: 400rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.image-section {
  margin-bottom: 30rpx;
}

.image-picker {
  display: flex;
  align-items: center;
}

.image-preview {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.delete-img {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #e74c3c;
  color: #fff;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 2rpx dashed #ddd;
}

.add-image .add-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.star-preview {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.preview-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.star-preview .star {
  font-size: 32rpx;
  color: #ffc107;
}

.submit-btn {
  margin: 0 30rpx;
  background-color: #4a90e2;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
}

.star-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.star-picker {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  z-index: 101;
}

.picker-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.picker-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.picker-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.star-row {
  display: flex;
  justify-content: center;
  margin-bottom: 50rpx;
}

.star-item {
  font-size: 60rpx;
  color: #ddd;
  margin: 0 10rpx;
  transition: all 0.2s;
}

.star-item.active {
  color: #ffc107;
  transform: scale(1.1);
}

.picker-btns {
  display: flex;
  justify-content: space-between;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 25rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
}

.btn-cancel {
  background-color: #f0f0f0;
  color: #666;
  margin-right: 20rpx;
}

.btn-confirm {
  background-color: #4a90e2;
  color: #fff;
}
